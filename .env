# RoadTrip Planner — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_DB=roadtrip
POSTGRES_USER=roadtrip
# REQUIRED: set a strong password
POSTGRES_PASSWORD=Mindspace09!

# ── Authentication ────────────────────────────────────────────────────
# REQUIRED: at least 32 random characters each (generate with: openssl rand -hex 32)
JWT_SECRET=c9c1da9ed2875e3d8494a95197e52c7284e6da12ab143a2a7ff86606b123e3f3
JWT_REFRESH_SECRET=bb4084d5dcb2572eb504cb2423e042a3d03e95709e48a8a64496e66d1457f681

# ── Email (password reset) ────────────────────────────────────────────
# Get free API key at: https://resend.com/
# Optional: password reset emails disabled if omitted
RESEND_API_KEY=re_ez2pdNg9_LoPbMxgEZAkuCzzzi4rE4299

# ── Frontend URL (used in email links) ────────────────────────────────
FRONTEND_URL=http://localhost

# ── OSRM Routing ──────────────────────────────────────────────────────
# Self-hosted OSRM container (default; recommended for production)
OSRM_BASE_URL=http://osrm:5000
# Alt: public demo (rate-limited, no SLA): https://router.project-osrm.org

# ── Unsplash (trip cover photos) ──────────────────────────────────────
# Get free access key at: https://unsplash.com/developers
# Free tier: 50 requests/hour; results are cached for 24h in the database
# Optional: cover photos disabled if omitted
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ── Logging ───────────────────────────────────────────────────────────
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info
